# Core runtime
TZ=America/New_York
PUID=1000
PGID=1000

# VPN / Gluetun
# Point to your local WireGuard config file (kept out of git).
VPN_WG_CONF=./nl-ams-wg-005.conf
FIREWALL_INPUT_PORTS=8080,8989,7878,3579

# Dashboard container + publish port
DASHBOARD_PORT=8081
DASHBOARD_PUBLIC_PORT=8090

# Internal service hostnames (usually keep defaults with network_mode service:gluetun)
RADARR_HOST=gluetun
SONARR_HOST=gluetun
SABNZBD_HOST=gluetun
OMBI_HOST=gluetun
GLUETUN_IP_FILE=/gluetun_state/ip
MEDIA_ROOT_DIR=/media

# VPN verification options (set what you use; leave others blank)
HOME_PUBLIC_IP=
VPN_ORG_KEYWORDS=
VPN_EXPECTED_IP=
VPN_EXPECTED_IPS=

# Backup service
BACKUP_INTERVAL_HOURS=24
RETENTION_DAYS=14

# VPN guard
VPN_GUARD_CHECK_INTERVAL_SECONDS=2
